<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chuizhipu.shop.mapper.OrderMapper">

    <resultMap id="orderMap" type="com.chuizhipu.shop.entity.Order">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="userId" column="user_id"/>
        <result property="status" column="status"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="discountAmount" column="discount_amount"/>
        <result property="freight" column="freight"/>
        <result property="payAmount" column="pay_amount"/>
        <result property="addressJson" column="address_json"/>
        <result property="remark" column="remark"/>
        <result property="payTime" column="pay_time"/>
        <result property="deliverTime" column="deliver_time"/>
        <result property="finishTime" column="finish_time"/>
        <result property="cancelTime" column="cancel_time"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectById" resultMap="orderMap">
        SELECT * FROM t_order WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="orderMap">
        SELECT * FROM t_order WHERE user_id = #{userId}
        <if test="status != null and status >= 0">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_order (order_no, user_id, status, total_amount, discount_amount,
                             freight, pay_amount, address_json, remark, create_time)
        VALUES (#{orderNo}, #{userId}, #{status}, #{totalAmount}, #{discountAmount},
                #{freight}, #{payAmount}, #{addressJson}, #{remark}, NOW())
    </insert>

    <update id="updateStatus">
        UPDATE t_order SET status = #{status}, update_time = NOW()
        <if test="status == 1">, pay_time = NOW()</if>
        <if test="status == 2">, deliver_time = NOW()</if>
        <if test="status == 3">, finish_time = NOW()</if>
        <if test="status == 5">, cancel_time = NOW()</if>
        WHERE id = #{id}
    </update>

</mapper>
