<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chuizhipu.shop.mapper.CategoryMapper">

    <resultMap id="categoryMap" type="com.chuizhipu.shop.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="icon" column="icon"/>
        <result property="parentId" column="parent_id"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectAll" resultMap="categoryMap">
        SELECT * FROM t_category ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectByParentId" resultMap="categoryMap">
        SELECT * FROM t_category WHERE parent_id = #{parentId} ORDER BY sort_order ASC
    </select>

    <select id="selectById" resultMap="categoryMap">
        SELECT * FROM t_category WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_category (name, icon, parent_id, sort_order)
        VALUES (#{name}, #{icon}, #{parentId}, #{sortOrder})
    </insert>

    <update id="updateById">
        UPDATE t_category SET name = #{name}, icon = #{icon}, sort_order = #{sortOrder}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM t_category WHERE id = #{id}
    </delete>

</mapper>
